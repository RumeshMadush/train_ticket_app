@model List<ChatMessage>
@{ ViewData["Title"] = "Forecast assistant"; }

<div class="page-heading">
    <div><div class="eyebrow">Pattern-based forecasts</div><h2>Ask RailFlow</h2><p>Explore predicted availability and pricing trends from schedules and booking patterns.</p></div>
</div>

<section class="surface-card chat-shell mx-auto">
    <aside class="chat-aside">
        <div class="assistant-orb"><i class="bi bi-stars"></i></div>
        <h2>Travel intelligence</h2>
        <p>This coursework prototype uses deterministic booking-pattern analysis. It does not call an external AI service.</p>
        <div class="suggestions">
            <button type="button" class="suggestion-btn" data-suggestion="Show all routes"><i class="bi bi-signpost-2 me-1"></i> Show all routes</button>
            <button type="button" class="suggestion-btn" data-suggestion="What are the busiest days?"><i class="bi bi-graph-up me-1"></i> Find busiest days</button>
            <button type="button" class="suggestion-btn" data-suggestion="Price from Colombo Fort to Kandy on Friday"><i class="bi bi-cash-stack me-1"></i> Predict Kandy fare</button>
            <button type="button" class="suggestion-btn" data-suggestion="Seats available from Colombo Fort to Galle on Monday"><i class="bi bi-people me-1"></i> Check Galle seats</button>
        </div>
    </aside>
    <div class="chat-main">
        <div class="chat-toolbar">
            <div><strong>RailFlow Assistant</strong><small><span class="status-dot d-inline-block me-2" style="width:6px;height:6px"></span>Ready to forecast</small></div>
            <form asp-action="Clear" method="post"><button type="submit" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-counterclockwise me-1"></i>Reset</button></form>
        </div>
        <div class="chat-messages" data-chat-messages>
            @foreach (var message in Model)
            {
                <div class="chat-row @(message.Role == "user" ? "user" : "bot")">
                    @if (message.Role != "user") { <span class="chat-avatar"><i class="bi bi-stars"></i></span> }
                    <div class="chat-bubble">@message.Text<div class="secondary-cell mt-2">@message.Timestamp.ToString("h:mm tt")</div></div>
                </div>
            }
        </div>
        <div class="chat-composer">
            <form asp-action="Send" method="post"><input class="form-control" type="text" name="message" data-chat-input placeholder="Ask about a route, date, fare or availability…" autocomplete="off" required /><button type="submit" class="btn btn-brand" aria-label="Send message"><i class="bi bi-send-fill"></i></button></form>
        </div>
    </div>
</section>
