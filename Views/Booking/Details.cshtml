@model Booking
@{ViewData["Title"]="Booking details";var schedule=ViewBag.Schedule as Schedule;var requests=ViewBag.Requests as List<SpecialRequest>??[];var upcoming=ViewBag.Upcoming as List<BookingOccurrence>??[];}
<div class="page-heading"><div><div class="eyebrow">@Model.ReferenceNumber</div><h2>@Model.PassengerName</h2><p>@Model.SeatCount reserved seat@(Model.SeatCount==1?"":"s") · Created @Model.CreatedAt.ToString("d MMM yyyy")</p></div><div class="d-flex gap-2"><a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary"><i class="bi bi-pencil me-1"></i>Edit</a><a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger"><i class="bi bi-trash3 me-1"></i>Delete</a></div></div>
<div class="detail-grid"><div><div class="surface-card card-pad mb-3"><div class="ticket-strip mb-3"><span class="type-badge bg-white text-primary">@(Model.BookingType==BookingKind.OneOff?"ONE-OFF":"RECURRING")</span><h3 class="mt-3">@Model.DepartureStation <i class="bi bi-arrow-right mx-2"></i> @Model.ArrivalStation</h3><p>@schedule?.TrainNumber · @Model.RecurrenceSummary</p></div><div class="detail-list"><div class="detail-item"><small>First occurrence</small><strong>@Model.TravelDate.ToString("dddd, d MMMM yyyy")</strong></div><div class="detail-item"><small>Departure</small><strong>@DateTime.Today.Add(Model.DepartureTime).ToString("h:mm tt")</strong></div><div class="detail-item"><small>Journey total</small><strong>Rs @Model.TotalPrice.ToString("N2")</strong></div><div class="detail-item"><small>Status</small><strong><span class="status-badge status-@Model.Status.ToString().ToLowerInvariant()">@Model.Status</span></strong></div></div></div>
<div class="surface-card card-pad"><div class="section-heading"><div><h3>Passenger seat assignments</h3><p>Repeated on every generated occurrence.</p></div></div><div class="reservation-summary-list">@foreach(var selection in Model.SeatSelections){var seat=schedule?.Seats.FirstOrDefault(item=>item.Id==selection.ScheduleSeatId);<div class="reservation-summary"><span class="avatar">@selection.PassengerName[..1].ToUpper()</span><div><strong>@selection.PassengerName</strong><small>@seat?.SeatNumber · @seat?.CoachNumber · @seat?.SeatClass</small></div><strong class="ms-auto">Rs @selection.ReservedPrice.ToString("N2")</strong></div>}</div></div></div>
<aside><div class="surface-card card-pad mb-3"><div class="section-heading"><div><h3>Upcoming occurrences</h3><p>Generated, not stored separately</p></div></div>@foreach(var item in upcoming){<div class="week-item"><strong>@item.TravelDate.ToString("ddd, d MMM") · @DateTime.Today.Add(item.Schedule.DepartureTime).ToString("h:mm tt")</strong><span>@item.OccurrenceId</span><span>@item.SeatCount seat(s) · Rs @item.TotalPrice.ToString("N2")</span></div>}@if(!upcoming.Any()){<p class="text-muted small">No future occurrence in the next 60 days.</p>}</div><div class="surface-card card-pad"><div class="section-heading"><div><h3>Special requests</h3><p>@requests.Count linked request(s)</p></div><a asp-controller="SpecialRequest" asp-action="Create" asp-route-bookingId="@Model.Id" class="btn btn-sm btn-soft"><i class="bi bi-plus"></i>Add</a></div>@foreach(var request in requests){<div class="week-item request"><strong>@request.RequestType</strong><span>@request.Description</span><span>Additional cost: Rs @request.AdditionalCost.ToString("N2")</span></div>}@if(!requests.Any()){<p class="text-muted small mb-0">No requests recorded.</p>}</div></aside></div>
