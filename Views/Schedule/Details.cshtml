@model Schedule
@{ ViewData["Title"] = "Schedule details"; }
<div class="page-heading"><div><div class="eyebrow">@Model.TrainNumber</div><h2>@Model.DepartureStation → @Model.ArrivalStation</h2><p>@Model.DaysRunningDisplay service</p></div><div class="d-flex gap-2"><a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-secondary"><i class="bi bi-pencil me-1"></i>Edit</a><a asp-controller="Booking" asp-action="Create" asp-route-scheduleId="@Model.Id" class="btn btn-brand"><i class="bi bi-ticket me-1"></i>Book train</a></div></div>
<div class="surface-card card-pad form-shell"><div class="ticket-strip mb-3"><span class="status-badge bg-white @(Model.IsActive ? "text-success" : "text-danger")">@(Model.IsActive ? "ACTIVE SERVICE" : "INACTIVE SERVICE")</span><h3 class="mt-3">@DateTime.Today.Add(Model.DepartureTime).ToString("h:mm tt") <i class="bi bi-arrow-right mx-3"></i> @DateTime.Today.Add(Model.ArrivalTime).ToString("h:mm tt")</h3><p>@((int)Model.Duration.TotalHours)h @Model.Duration.Minutes.ToString("00")m journey · Route #@Model.RouteId</p></div><div class="detail-list"><div class="detail-item"><small>Running days</small><strong>@Model.DaysRunningDisplay</strong></div><div class="detail-item"><small>Seat catalogue</small><strong>@Model.TotalSeats total · @Model.StandardSeatCount standard · @Model.FirstClassSeatCount first</strong></div><div class="detail-item"><small>Standard fare</small><strong>Rs @Model.StandardPrice.ToString("N2")</strong></div><div class="detail-item"><small>First class fare</small><strong>Rs @Model.FirstClassPrice.ToString("N2")</strong></div></div></div>
