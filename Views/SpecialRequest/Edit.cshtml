@model SpecialRequest
@{ ViewData["Title"] = "Edit special request"; }
<div class="form-shell" style="max-width:820px"><div class="page-heading"><div><div class="eyebrow">#RQ-@Model.Id.ToString("D4")</div><h2>Edit special request</h2><p>Update the requirement, linked booking, date or status.</p></div></div><form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="surface-card"><input asp-for="Id" type="hidden" /><input asp-for="CreatedAt" type="hidden" /><input asp-for="PassengerName" type="hidden" /><partial name="_RequestForm" model="Model" /><div class="form-actions"><a asp-action="Index" class="btn btn-outline-secondary">Cancel</a><button class="btn btn-brand"><i class="bi bi-check2 me-1"></i>Save changes</button></div></form></div>
