@model IReadOnlyList<SpecialRequest>
@{ ViewData["Title"] = "Special requests"; }
<div class="page-heading"><div><div class="eyebrow">Travel preferences</div><h2>Special requests</h2><p>Manage assistance, meals, seating preferences and other booking needs.</p></div><a asp-action="Create" class="btn btn-brand"><i class="bi bi-plus-lg me-1"></i>Add request</a></div>
<form method="get" class="surface-card filter-bar" style="grid-template-columns:minmax(180px,280px) auto"><select name="status" class="form-select"><option value="">All statuses</option>@foreach (var status in Enum.GetValues<RequestStatus>()) { <option value="@status" selected="@(ViewBag.Status?.ToString() == status.ToString())">@status</option> }</select><button class="btn btn-soft"><i class="bi bi-funnel me-1"></i>Filter</button></form>
<section class="surface-card"><div class="card-pad section-heading mb-0"><div><h3>@Model.Count request@(Model.Count == 1 ? "" : "s")</h3><p>Requests appear alongside journeys in the weekly report.</p></div></div>
@if (Model.Any()) { <div class="table-responsive"><table class="data-table"><thead><tr><th>Passenger</th><th>Booking</th><th>Request</th><th>Description</th><th>Date needed</th><th>Status</th><th></th></tr></thead><tbody>
@foreach (var request in Model) { <tr><td><div class="d-flex align-items-center gap-2"><span class="avatar">@request.PassengerName[..1].ToUpper()</span><div class="primary-cell">@request.PassengerName</div></div></td><td><a asp-controller="Booking" asp-action="Details" asp-route-id="@request.BookingId" class="type-badge type-oneoff text-decoration-none">#BK-@request.BookingId.ToString("D4")</a></td><td><div class="primary-cell">@request.RequestType</div><div class="secondary-cell">#RQ-@request.Id.ToString("D4")</div></td><td style="max-width:300px"><span>@request.Description</span><div class="secondary-cell">Additional Rs @request.AdditionalCost.ToString("N2")</div></td><td><div class="primary-cell">@request.DateNeeded.ToString("d MMM yyyy")</div><div class="secondary-cell">@request.DateNeeded.ToString("dddd")</div></td><td><span class="status-badge status-@request.Status.ToString().ToLowerInvariant()">@request.Status</span></td><td><div class="d-flex gap-1"><a asp-action="Edit" asp-route-id="@request.Id" class="btn btn-sm btn-outline-secondary"><i class="bi bi-pencil"></i></a><a asp-action="Delete" asp-route-id="@request.Id" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash3"></i></a></div></td></tr> }
</tbody></table></div> } else { <div class="empty-state"><div class="empty-state-icon"><i class="bi bi-stars"></i></div><h3>No special requests</h3><p>Add one from here or immediately after creating a booking.</p></div> }
</section>
