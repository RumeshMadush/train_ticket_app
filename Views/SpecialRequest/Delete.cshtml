@model SpecialRequest
@{ ViewData["Title"] = "Delete special request"; }
<div class="form-shell" style="max-width:650px"><div class="page-heading"><div><div class="eyebrow text-danger">Request removal</div><h2>Delete this request?</h2><p>#RQ-@Model.Id.ToString("D4") · @Model.PassengerName</p></div></div><div class="surface-card card-pad"><div class="week-item request mb-4"><strong>@Model.RequestType</strong><span>@Model.Description</span><span>Needed @Model.DateNeeded.ToString("d MMM yyyy")</span></div><form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-flex justify-content-end gap-2"><a asp-action="Index" class="btn btn-outline-secondary">Cancel</a><button class="btn btn-danger"><i class="bi bi-trash3 me-1"></i>Delete request</button></form></div></div>
