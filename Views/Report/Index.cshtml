@model WeeklyReport
@{ViewData["Title"]="Weekly report";}
<div class="page-heading"><div><div class="eyebrow">Seven-day occurrence report</div><h2>@Model.WeekStart.ToString("d MMM") – @Model.WeekEnd.ToString("d MMM yyyy")</h2><p>Generated occurrences, passenger seats, requests and combined travel costs.</p></div><div class="week-toolbar no-print"><a asp-action="Index" asp-route-weekOf="@Model.WeekStart.AddDays(-7).ToString("yyyy-MM-dd")" class="btn btn-outline-secondary"><i class="bi bi-chevron-left"></i></a><form method="get" class="d-flex gap-2"><input type="date" name="weekOf" value="@Model.WeekStart.ToString("yyyy-MM-dd")" class="form-control"/><button class="btn btn-soft">Go</button></form><a asp-action="Index" asp-route-weekOf="@Model.WeekStart.AddDays(7).ToString("yyyy-MM-dd")" class="btn btn-outline-secondary"><i class="bi bi-chevron-right"></i></a><button class="btn btn-outline-secondary" onclick="window.print()"><i class="bi bi-printer"></i></button></div></div>
<div class="week-summary report-summary"><div class="surface-card"><span class="metric-icon tone-indigo"><i class="bi bi-ticket-perforated"></i></span><div><strong>@Model.TotalBookings</strong><small>Occurrences</small></div></div><div class="surface-card"><span class="metric-icon tone-teal"><i class="bi bi-people"></i></span><div><strong>@Model.TotalSeats</strong><small>Reserved seats</small></div></div><div class="surface-card"><span class="metric-icon tone-orange"><i class="bi bi-stars"></i></span><div><strong>@Model.TotalRequests</strong><small>Requests</small></div></div><div class="surface-card"><span class="metric-icon tone-rose"><i class="bi bi-cash-stack"></i></span><div><strong>Rs @Model.TotalCost.ToString("N2")</strong><small>Fare + request cost</small></div></div></div>
<section class="surface-card card-pad"><div class="section-heading"><div><h3>Day-by-day summary</h3><p>Exactly seven summaries; recurring series are expanded on demand.</p></div></div><div class="week-grid">@foreach(var day in Model.Days){<div class="day-column"><div class="day-header @(day.Date==DateTime.Today?"today":"")"><strong>@day.Date.ToString("dddd")</strong><span>@day.Date.ToString("d MMM") · @day.ReservedSeats seats</span></div><div class="day-content">@foreach(var occurrence in day.Occurrences){<div class="week-item"><strong>@occurrence.Schedule.DepartureStation → @occurrence.Schedule.ArrivalStation</strong><span>@DateTime.Today.Add(occurrence.Schedule.DepartureTime).ToString("h:mm tt") · @occurrence.SeatCount seat(s)</span><span>@string.Join(", ",occurrence.SeatReservations.Where(item=>item.Status==ReservationStatus.Active).Select(item=>$"{item.PassengerName} ({item.Seat.SeatNumber})"))</span><span>@occurrence.OccurrenceId · Rs @occurrence.TotalPrice.ToString("N2")</span></div>}@foreach(var request in day.SpecialRequests){<div class="week-item request"><strong><i class="bi bi-stars me-1"></i>@request.RequestType</strong><span>@request.PassengerName</span><span>@request.Description</span><span>+ Rs @request.AdditionalCost.ToString("N2")</span></div>}@if(!day.Occurrences.Any()&&!day.SpecialRequests.Any()){<div class="day-empty"><i class="bi bi-dash-circle d-block"></i>No activity</div>}</div></div>}</div></section>
